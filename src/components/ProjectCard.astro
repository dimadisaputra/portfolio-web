---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  category: string;
  slug?: string;
  repoURL?: string;
}

const { title, description, image, imageAlt, category, slug, repoURL } =
  Astro.props;

// Pemetaan dari kategori ke kelas warna dengan gradient
const categoryStyles: {
  [key: string]: { text: string; bg: string; gradient: string };
} = {
  "Data & AI": {
    text: "text-blue-crayola",
    bg: "bg-blue-crayola/10",
    gradient: "from-blue-crayola/20 to-blue-600/20",
  },
  "Web & App": {
    text: "text-sunglow",
    bg: "bg-sunglow/10",
    gradient: "from-sunglow/20 to-yellow-600/20",
  },
  Game: {
    text: "text-poppy",
    bg: "bg-poppy/10",
    gradient: "from-poppy/20 to-red-600/20",
  },
  Fun: {
    text: "text-purple-600",
    bg: "bg-purple-100",
    gradient: "from-purple-500/20 to-pink-500/20",
  },
};

const categoryStyle = categoryStyles[category] || {
  text: "text-gray-600",
  bg: "bg-gray-100",
  gradient: "from-gray-400/20 to-gray-600/20",
};
---

<div
  data-href={slug ? `/projects/${slug}` : undefined}
  class="project-card group block bg-white rounded-3xl shadow-md border border-gray-100 overflow-hidden hover:shadow-2xl hover:border-gray-200 transition-all duration-500 hover:-translate-y-2 will-change-transform cursor-pointer"
>
  <!-- Image Container with Overlay -->
  <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
    <!-- Gradient Overlay -->
    <div
      class:list={[
        "absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10",
        `bg-gradient-to-br ${categoryStyle.gradient}`,
      ]}
    >
    </div>

    <!-- Image -->
    <Image
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:rotate-1"
      loading="lazy"
      format="webp"
    />

    <!-- Category Badge on Image -->
    <div class="absolute top-4 left-4 z-20">
      <span
        class:list={[
          "inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1.5 rounded-full backdrop-blur-sm border shadow-lg transition-all duration-300",
          categoryStyle.text,
          categoryStyle.bg,
          "border-white/50 group-hover:scale-110",
        ]}
      >
        {category}
      </span>
    </div>

    {/* Repository Link Badge on Image */}
    {
      repoURL && (
        <a
          href={repoURL}
          target="_blank"
          rel="noopener noreferrer"
          class="repo-badge absolute top-4 right-4 z-30 inline-flex items-center justify-center w-9 h-9 rounded-full bg-black/60 backdrop-blur-sm border border-white/20 text-white shadow-lg hover:bg-black/80 hover:scale-110 hover:shadow-xl transition-all duration-300"
          title="View Repository"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4.5 w-4.5"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
        </a>
      )
    }
  </div>

  <!-- Content -->
  <div class="p-6 relative">
    <!-- Decorative Corner -->
    <div
      class:list={[
        "absolute top-0 right-0 w-20 h-20 bg-gradient-to-br opacity-0 group-hover:opacity-10 transition-opacity duration-500 rounded-bl-full",
        `bg-gradient-to-br ${categoryStyle.gradient}`,
      ]}
    >
    </div>

    <h3
      class:list={[
        "text-xl text-center font-bold text-black-alt mb-3 line-clamp-2 transition-colors duration-300",
        "relative",
      ]}
    >
      <span
        class:list={[
          "absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300",
          categoryStyle.text,
        ]}
      >
        {title}
      </span>
      <span class="group-hover:opacity-0 transition-opacity duration-300">
        {title}
      </span>
    </h3>

    <p class="text-sm text-gray-600 leading-relaxed line-clamp-3 mb-4">
      {description}
    </p>

    <!-- Read More Link -->
    <div
      class:list={[
        "flex items-center text-sm font-semibold group-hover:gap-2 transition-all duration-300",
        categoryStyle.text,
      ]}
    >
      <span>View project</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-300"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
          clip-rule="evenodd"></path>
      </svg>
    </div>
  </div>
</div>

<style>
  /* Line clamp utilities */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  document.querySelectorAll<HTMLDivElement>(".project-card").forEach((card) => {
    card.addEventListener("click", (e) => {
      // Don't navigate if clicking the repo badge
      if ((e.target as HTMLElement).closest(".repo-badge")) return;
      const href = card.dataset.href;
      if (href) window.location.href = href;
    });
  });
</script>
